---
import Layout from '../layouts/Layout.astro';
---

<Layout title="100% Private Pool & Backyard Deck | Ellamin Courtyard Retreat" description="Verify pool privacy, sizing parameters, and deck layouts. No shared gates, no overlapping bookings.">
  <section class="v3-band pb-12">
    <div class="v3-container">
      <div class="mb-7">
        <p class="v3-eyebrow">Proof Strip</p>
        <h2 class="v3-section-title mt-3 font-display">100% Private Swimming Pool</h2>
        <p class="mt-4 text-[color:var(--muted)] max-w-2xl leading-relaxed">
          Verify pool privacy, sizing parameters, and deck layouts. No shared gates, no overlapping bookings.
        </p>
      </div>

      <!-- Slogan vs Proof Breakdown -->
      <div class="v3-feature mt-10">
        <div class="v3-media-frame min-h-[440px]">
          <img class="v3-theme-day" src="/images/ellamin-courtyard-day-main.webp" alt="Daytime private pool, gazebo, pergola, BBQ bay, and lawn at Ellamin Courtyard" loading="eager">
          <img class="v3-theme-night" src="/images/ellamin-courtyard-night-pool.webp" alt="Night private pool with warm deck lighting at Ellamin Courtyard" loading="eager">
          <span class="v3-media-label">Actual exterior: day proof in light mode, night pool ambience in dark mode</span>
        </div>
        <article class="v3-card v3-fact-panel">
          <p class="v3-eyebrow text-[#dfc184]">Access & Safety Invariants</p>
          <h3 class="font-display mt-3 text-[clamp(31px,4vw,48px)] font-black leading-none">Exclusive Courtyard Access</h3>
          <p class="mt-4 text-sm leading-relaxed text-white/80">
            The pool sits directly inside the central courtyard. Access is protected by keyless smart locks. Only guests registered to your specific reservation have codes to open the patio doors.
          </p>
          <ul class="v3-fact-list text-xs">
            <li><strong>Private setting:</strong> pool, gazebo, pergola, lawn, and BBQ bay are all inside the walled courtyard.</li>
            <li><strong>Day and night use:</strong> daylight gathering works for families; warm deck lighting supports calmer evening swimming.</li>
            <li><strong>Host confirmation:</strong> final rules and timing are confirmed in WhatsApp before deposit.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- Poolside Deck & BBQ Amenities -->
  <section class="pb-16">
    <div class="v3-container">
      <div class="v3-logistics">
        <article class="v3-card">
          <div class="flex items-center gap-3">
            <span class="text-2xl" aria-hidden="true">🍖</span>
            <strong>Barbecue Station</strong>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-[color:var(--muted)]">
            Premium charcoal grill and outdoor dining table set up beside the lawn. Bring your own charcoal and ingredients.
          </p>
        </article>

        <article class="v3-card">
          <div class="flex items-center gap-3">
            <span class="text-2xl" aria-hidden="true">💡</span>
            <strong>Illuminated Swimming</strong>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-[color:var(--muted)]">
            Underwater lighting and string-lit gazebo area allow safe and highly atmospheric night swims up to 10:00 PM.
          </p>
        </article>

        <article class="v3-card">
          <div class="flex items-center gap-3">
            <span class="text-2xl" aria-hidden="true">📋</span>
            <strong>Pool Rules</strong>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-[color:var(--muted)]">
            Children must be supervised by adults at all times. Proper swimwear is required. No glassware is allowed on the wet deck.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="pb-24">
    <div class="v3-container">
      <div class="v3-final">
        <div>
          <h4 class="font-display text-[clamp(31px,4vw,48px)] font-black leading-none">Ready for a private swim?</h4>
          <p class="mt-3 leading-relaxed text-[#dfc184]">Check availability today and send Adrian your dates.</p>
        </div>
        <a href="/book" class="v3-button bg-white text-[color:var(--deep-pool)] hover:bg-[color:var(--warm)] whitespace-nowrap">
          Check Availability
        </a>
      </div>
    </div>
  </section>
</Layout>
